# Development environment — used when running API/web locally against docker-compose.dev.yml
# Copy to apps/api/.env and apps/web/.env.local (or set as process env)

# --- App ---
APP_NAME="Enterprise Dev"
APP_URL=http://localhost:3000
NODE_ENV=development

# --- Database (postgres exposed on host port 5433, avoids conflict with local postgres) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/enterprise

# --- Redis (exposed on host port 6379) ---
REDIS_URL=redis://localhost:6379

# --- Keycloak (exposed on host port 8080) ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=enterprise
KEYCLOAK_CLIENT_ID=enterprise-app

# --- MinIO (exposed on host port 9000) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_CHAT=chat-media
MINIO_BUCKET_KANBAN=kanban-attachments

# --- JWT ---
JWT_PUBLIC_KEY_URL=http://localhost:8080/realms/enterprise/protocol/openid-connect/certs

# --- Microsoft Graph (leave blank to disable — tokens won't work without real Azure app) ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/oauth/microsoft/callback
MICROSOFT_ENCRYPTION_KEY=dev-only-insecure-key-change-me-in-production

# --- Next.js public env vars ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=enterprise
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=enterprise-app
NEXT_PUBLIC_APP_NAME="Enterprise Dev"

# --- Keycloak Admin ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
