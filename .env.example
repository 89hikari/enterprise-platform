# ============================================================
# Enterprise Platform — Environment Variables
# Copy this file to .env and fill in values before running.
# ============================================================

# --- App ---
APP_NAME="My Company"
APP_URL=http://localhost
NODE_ENV=production

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=enterprise_platform
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme_db_password
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# --- Keycloak ---
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=enterprise
KEYCLOAK_CLIENT_ID=enterprise-app
KEYCLOAK_CLIENT_SECRET=changeme_keycloak_secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak_admin

# --- MinIO ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_CHAT=chat-media
MINIO_BUCKET_KANBAN=kanban-attachments

# --- JWT ---
JWT_PUBLIC_KEY_URL=${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/certs

# --- Microsoft Graph (optional — leave blank to disable integration) ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=${APP_URL}/api/oauth/microsoft/callback
# AES-256-GCM key for encrypting stored OAuth tokens — generate with: openssl rand -hex 32
MICROSOFT_ENCRYPTION_KEY=changeme_generate_with_openssl_rand_hex_32

# --- NestJS API ---
API_PORT=3001

# --- Next.js ---
NEXT_PUBLIC_API_URL=${APP_URL}/api
NEXT_PUBLIC_WS_URL=${APP_URL}
NEXT_PUBLIC_KEYCLOAK_URL=${APP_URL}/auth
NEXT_PUBLIC_KEYCLOAK_REALM=${KEYCLOAK_REALM}
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=${KEYCLOAK_CLIENT_ID}
